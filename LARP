@bot.tree.command(
    name="role",
    description="Add a role to a user.",
    guild=GUILD_OBJECT,
)
@app_commands.describe(
    member="User to give the role",
    role="Role to add",
)
@app_commands.guild_only()
async def role(
    interaction: discord.Interaction,
    member: discord.Member,
    role: discord.Role,
):

    if not interaction.user.guild_permissions.manage_roles:

        await send_error(
            interaction,
            "You need Manage Roles permission.",
        )

        return



    if role >= interaction.guild.me.top_role:

        await send_error(
            interaction,
            "I cannot give this role.",
        )

        return



    if role in member.roles:

        await send_error(
            interaction,
            "This user already has this role.",
        )

        return



    await member.add_roles(
        role,
        reason=f"Role added by {interaction.user}",
    )


    await interaction.response.send_message(
        f":white_check_mark: I've successfully added the role "
        f"{role.mention} to {member.mention}",
        allowed_mentions=discord.AllowedMentions(
            users=True,
            roles=True,
        ),
    )
