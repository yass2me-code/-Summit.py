async def send_error(
    interaction: discord.Interaction,
    message: str,
):

    if interaction.response.is_done():

        await interaction.edit_original_response(
            content=f"❌ {message}",
            embed=None,
        )

    else:

        await interaction.response.send_message(
            f"❌ {message}",
            ephemeral=True,
        )



def get_embed_colour(
    role: discord.Role
):

    if role.colour.value == 0:

        return discord.Colour.blurple()

    return role.colour
# =========================================================
# PROMOTION EMBEDS
# =========================================================

def make_promotion_embed(
    *,
    member: discord.Member,
    promoter: discord.Member,
    role: discord.Role,
    reason: str,
    case_id: int,
):

    embed = discord.Embed(
        title="Staff Promotion",
        description=(
            f"**Staff Member:** {member.mention}\n"
            f"**New Rank:** {role.mention}\n"
            f"**Reason:** {reason}\n"
            f"**Case ID:** `{case_id}`\n\n"
            f"Promoted by {promoter.mention}"
        ),
        colour=get_embed_colour(role),
        timestamp=discord.utils.utcnow(),
    )


    embed.set_thumbnail(
        url=member.display_avatar.url
    )

    embed.set_image(
        url=PROMO_IMAGE_URL
    )


    return embed




def make_promotion_dm_embed(
    *,
    member: discord.Member,
    promoter: discord.Member,
    role: discord.Role,
    reason: str,
    case_id: int,
    guild: discord.Guild,
):


    embed = discord.Embed(
        title="You Have Been Promoted!",
        description=(
            f"**Staff Member:** {member.mention}\n"
            f"**New Rank:** {role.mention}\n"
            f"**Reason:** {reason}\n"
            f"**Case ID:** `{case_id}`\n\n"
            f"Promoted by {promoter.mention}"
        ),
        colour=get_embed_colour(role),
        timestamp=discord.utils.utcnow(),
    )


    embed.set_author(
        name=guild.name,
        icon_url=(
            guild.icon.url
            if guild.icon
            else None
        ),
    )


    embed.set_thumbnail(
        url=member.display_avatar.url
    )


    embed.set_image(
        url=PROMO_IMAGE_URL
    )


    return embed
# =========================================================
# /PROMOTE COMMAND
# =========================================================

@bot.tree.command(
    name="promote",
    description="Promote a staff member.",
    guild=GUILD_OBJECT,
)
@app_commands.describe(
    member="The member to promote",
    role="The rank to give",
    reason="Promotion reason",
)
@app_commands.guild_only()
async def promote(
    interaction: discord.Interaction,
    member: discord.Member,
    role: discord.Role,
    reason: str,
):

    guild = interaction.guild
    promoter = interaction.user


    if guild is None:
        return


    # Permission role

    permission_role = guild.get_role(
        PROMOTE_PERMISSION_ROLE_ID
    )


    if permission_role not in promoter.roles:

        await send_error(
            interaction,
            "You do not have permission to use this command.",
        )

        return



    if member.bot:

        await send_error(
            interaction,
            "You cannot promote bots.",
        )

        return



    if role >= guild.me.top_role:

        await send_error(
            interaction,
            "I cannot give this role.",
        )

        return



    await interaction.response.defer(
        thinking=True
    )



    try:

        await member.add_roles(
            role,
            reason=f"Promotion by {promoter}: {reason}",
        )


    except discord.Forbidden:

        await send_error(
            interaction,
            "I cannot add this role.",
        )

        return



    case_id = await save_promotion(
        guild_id=guild.id,
        promoted_user_id=member.id,
        promoter_user_id=promoter.id,
        role_id=role.id,
        reason=reason,
    )



    embed = make_promotion_embed(
        member=member,
        promoter=promoter,
        role=role,
        reason=reason,
        case_id=case_id,
    )



    # Send log

    channel = guild.get_channel(
        PROMOTION_LOG_CHANNEL_ID
    )


    if channel:

        await channel.send(
            content=member.mention,
            embed=embed,
            allowed_mentions=discord.AllowedMentions(
                users=True
            ),
        )



    # DM

    try:

        dm_embed = make_promotion_dm_embed(
            member=member,
            promoter=promoter,
            role=role,
            reason=reason,
            case_id=case_id,
            guild=guild,
        )


        await member.send(
            embed=dm_embed
        )


    except discord.Forbidden:

        pass



    # Command confirmation

    await interaction.edit_original_response(
        content=(
            f":check: {member.mention} has been promoted "
            f"to {role.mention}"
        )
    )
