@bot.tree.command(
    name="voidpromotion",
    description="Void a promotion.",
    guild=GUILD_OBJECT,
)
@app_commands.describe(
    case_id="Promotion case ID",
)
@app_commands.guild_only()
async def voidpromotion(
    interaction: discord.Interaction,
    case_id: int,
):

    guild = interaction.guild
    user = interaction.user


    if guild is None:
        return



    with sqlite3.connect(DATABASE_PATH) as database:

        promotion = database.execute(
            """
            SELECT promoted_user_id, role_id, status
            FROM promotions
            WHERE id = ?
            AND guild_id = ?
            """,
            (
                case_id,
                guild.id,
            ),
        ).fetchone()



    if promotion is None:

        await send_error(
            interaction,
            "Promotion case not found.",
        )

        return



    if promotion[2] == "Voided":

        await send_error(
            interaction,
            "This promotion is already voided.",
        )

        return



    member = guild.get_member(
        promotion[0]
    )

    role = guild.get_role(
        promotion[1]
    )



    if member and role:

        try:

            await member.remove_roles(
                role,
                reason=f"Promotion #{case_id} voided by {user}",
            )

        except discord.Forbidden:

            pass



    with sqlite3.connect(DATABASE_PATH) as database:

        database.execute(
            """
            UPDATE promotions
            SET status = 'Voided'
            WHERE id = ?
            """,
            (case_id,),
        )

        database.commit()



    embed = discord.Embed(
        title="Promotion Voided",
        description=(
            f"Promotion `{case_id}` has been "
            f"voided by {user.mention}"
        ),
        colour=discord.Colour.blue(),
        timestamp=discord.utils.utcnow(),
    )


    await interaction.response.send_message(
        embed=embed
    )




