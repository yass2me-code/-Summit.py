@bot.tree.command(
    name="promotion-list",
    description="Show promotions of a user.",
    guild=GUILD_OBJECT,
)
@app_commands.describe(
    member="User to check",
)
@app_commands.guild_only()
async def promotion_list(
    interaction: discord.Interaction,
    member: discord.Member,
):

    guild = interaction.guild


    if guild is None:
        return



    with sqlite3.connect(DATABASE_PATH) as database:

        promotions = database.execute(
            """
            SELECT
                id,
                role_id,
                reason,
                status,
                created_at
            FROM promotions
            WHERE promoted_user_id = ?
            AND guild_id = ?
            ORDER BY id DESC
            """,
            (
                member.id,
                guild.id,
            ),
        ).fetchall()



    if not promotions:

        await interaction.response.send_message(
            "No promotions found.",
            ephemeral=True,
        )

        return



    embed = discord.Embed(
        title=f"Promotion History - {member}",
        colour=discord.Colour.blue(),
    )


    for promo in promotions:

        case_id, role_id, reason, status, date = promo

        role = guild.get_role(role_id)


        embed.add_field(
            name=f"Promotion #{case_id}",
            value=(
                f"**Role:** {role.mention if role else 'Unknown'}\n"
                f"**Reason:** {reason}\n"
                f"**Status:** {status}\n"
                f"**Date:** {date}"
            ),
            inline=False,
        )


    await interaction.response.send_message(
        embed=embed
    )
