@bot.tree.command(
    name="infraction",
    description="Give an infraction to a user.",
    guild=GUILD_OBJECT,
)
@app_commands.describe(
    member="User receiving the infraction",
    action="Infraction type",
    reason="Reason",
    notes="Notes",
)
@app_commands.choices(
    action=[
        app_commands.Choice(name="Verbal Warning", value="Verbal Warning"),
        app_commands.Choice(name="Warning", value="Warning"),
        app_commands.Choice(name="Strike", value="Strike"),
        app_commands.Choice(name="Suspension", value="Suspension"),
        app_commands.Choice(name="Termination", value="Termination"),
        app_commands.Choice(name="Blacklist", value="Blacklist"),
        app_commands.Choice(name="Retirement", value="Retirement"),
    ]
)
@app_commands.guild_only()
async def infraction(
    interaction: discord.Interaction,
    member: discord.Member,
    action: app_commands.Choice[str],
    reason: str,
    notes: str,
):

    guild = interaction.guild
    staff = interaction.user


    if guild is None:
        return


    permission_role = guild.get_role(
        INFRACTION_PERMISSION_ROLE_ID
    )


    if permission_role not in staff.roles:

        await send_error(
            interaction,
            "You do not have permission to use this command.",
        )

        return



    await interaction.response.defer(
        thinking=True
    )



    case_id = await save_infraction(
        guild_id=guild.id,
        user_id=member.id,
        infracter_id=staff.id,
        action=action.value,
        reason=reason,
        notes=notes,
    )



    embed = discord.Embed(
        title="LARP Infraction",
        description=(
            f"**Staff Member:** {member.mention}\n"
            f"**Action:** {action.value}\n"
            f"**Reason:** {reason}\n"
            f"**Notes:** {notes}\n"
            f"**Case ID:** `{case_id}`\n"
            f"**Infracted by:** {staff.mention}"
        ),
        colour=discord.Colour.red(),
        timestamp=discord.utils.utcnow(),
    )


    embed.set_image(
        url=INFRACTION_IMAGE_URL
    )



    # DM user

    try:

        await member.send(
            embed=embed
        )

    except discord.Forbidden:

        pass



    # Send infraction log

    channel = guild.get_channel(
        INFRACTION_LOG_CHANNEL_ID
    )


    if channel:

        await channel.send(
            content=member.mention,
            embed=embed,
            allowed_mentions=discord.AllowedMentions(
                users=True
            ),
        )



    # Confirmation

    await interaction.edit_original_response(
        content=(
            f":check: {member.mention} has been "
            f"infracted with {action.value}"
        )
    )
